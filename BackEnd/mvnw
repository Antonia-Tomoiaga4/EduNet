#!/bin/sh
# Download Maven if not present and run
set -e

MAVEN_VERSION="3.9.6"
MAVEN_HOME="${MAVEN_HOME:-.mvn}"
MAVEN_URL="https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.zip"

if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven $MAVEN_VERSION..."
    mkdir -p "$MAVEN_HOME"
    curl -fsSL "$MAVEN_URL" -o /tmp/maven.zip
    unzip -q /tmp/maven.zip -d "$MAVEN_HOME"
    rm /tmp/maven.zip
    export PATH="$MAVEN_HOME/apache-maven-${MAVEN_VERSION}/bin:$PATH"
fi

"$MAVEN_HOME/apache-maven-${MAVEN_VERSION}/bin/mvn" "$@"
